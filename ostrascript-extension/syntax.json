{
    "name": "Ostrascript",
    "scopeName": "source.os",
    "patterns": [
        {
            "name": "comment.line.double-slash.ostrascript",
            "match": "//.*$"
        },
        {
            "name": "string.quoted.double.ostrascript",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.ostrascript",
                    "match": "\\\\."
                }
            ]
        },
        {
            "name": "meta.function.definition.ostrascript",
            "begin": "\\b(kalfas)\\s+([a-zA-Z_$][\\w$]*)?\\s*\\(",
            "beginCaptures": {
                "1": { "name": "storage.type.ostrascript" },
                "2": { "name": "entity.name.function.ostrascript" }
            },
            "end": "\\)",
            "patterns": [
                {
                    "name": "variable.parameter.ostrascript",
                    "match": "[a-zA-Z_$][\\w$]*"
                }
            ]
        },
        {
            "name": "meta.method-call.ostrascript",
            "match": "\\.([a-zA-Z_$][\\w$]*)",
            "captures": {
                "1": { "name": "entity.name.function.ostrascript" }
            }
        },
        {
            "name": "meta.type.definition.ostrascript",
            "match": "\\b(typ)\\s+([a-zA-Z_$][\\w$]*)\\b",
            "captures": {
                "1": { "name": "storage.type.ostrascript" },
                "2": { "name": "entity.name.type.ostrascript" }
            }
        },
        {
            "name": "meta.catch.ostrascript",
            "match": "\\b(chujstym)\\s*\\(\\s*([a-zA-Z_$][\\w$]*)\\s*\\)",
            "captures": {
                "1": { "name": "keyword.control.ostrascript" },
                "2": { "name": "variable.parameter.ostrascript" }
            }
        },
        {
            "name": "keyword.operator.assignment.ostrascript",
            "match": "="
        },
        {
            "name": "constant.numeric.ostrascript",
            "match": "\\b[0-9]+(?:\\.[0-9]+)?\\b"
        },
        {
            "name": "keyword.control.ostrascript",
            "match": "\\b(kaj|inak|kajinak|fajront|rubat|zkus|chujstym|fofrem|pockej|smrt|naposled|mrdni|novabuchta)\\b"
        },
        {
            "name": "storage.type.ostrascript",
            "match": "\\b(kalfas|toz|konstatuj|tryda|typ|pruser|slyb)\\b"
        },
        {
            "name": "keyword.operator.logical.ostrascript",
            "match": "\\b(aj|ci|ajbit|cibit)\\b"
        },
        {
            "name": "keyword.operator.arrow.ostrascript",
            "match": "=>"
        },
        {
            "name": "constant.language.ostrascript",
            "match": "\\b(laces|bokdepa|chuj|kokot)\\b"
        },
        {
            "name": "support.function.ostrascript",
            "match": "\\b(hovor|rubej)\\b"
        },
        {
            "name": "support.type.ostrascript",
            "match": "\\b(cyslo|dryst|lacesnebochuj|tryda|dynamit|buchta|ništ)\\b"
        }
    ]
}