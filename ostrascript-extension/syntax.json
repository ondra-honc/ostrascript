{
    "name": "Ostrascript",
    "scopeName": "source.os",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#generics"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#constants"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.ostrascript",
                    "match": "//.*$"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.ostrascript",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "include": "#string-internals"
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.ostrascript",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "include": "#string-internals-no-interpolation"
                        }
                    ]
                },
                {
                    "name": "string.quoted.template.ostrascript",
                    "begin": "`",
                    "end": "`",
                    "patterns": [
                        {
                            "include": "#string-internals"
                        }
                    ]
                }
            ]
        },
        "string-internals-no-interpolation": {
            "patterns": [
                {
                    "name": "constant.character.escape.ostrascript",
                    "match": "\\\\."
                }
            ]
        },
        "string-internals": {
            "patterns": [
                {
                    "include": "#string-internals-no-interpolation"
                },
                {
                    "name": "meta.interpolation.ostrascript",
                    "begin": "(\\$)(\\{)",
                    "beginCaptures": {
                        "1": {
                            "name": "keyword.operator.interpolation.ostrascript"
                        },
                        "2": {
                            "name": "keyword.operator.interpolation.ostrascript"
                        }
                    },
                    "end": "(\\})",
                    "endCaptures": {
                        "1": {
                            "name": "keyword.operator.interpolation.ostrascript"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#main",
                            "name": "source.os"
                        }
                    ]
                }
            ]
        },
        "generics": {
            "patterns": [
                {
                    "name": "meta.type.generic.ostrascript",
                    "match": "(\\b[a-zA-Z_$][\\w$]*)(\\s*)(<)",
                    "captures": {
                        "1": {
                            "name": "entity.name.type.ostrascript"
                        },
                        "3": {
                            "name": "entity.name.function.ostrascript"
                        }
                    }
                },
                {
                    "name": "entity.name.function.ostrascript",
                    "match": ">"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.arrow.ostrascript",
                    "match": "=>"
                },
                {
                    "name": "keyword.operator.comparison.ostrascript",
                    "match": "(<=|>=|===|==|!=|<|>)"
                },
                {
                    "name": "keyword.operator.arithmetic.ostrascript",
                    "match": "[*+\\-%/]"
                },
                {
                    "name": "keyword.operator.assignment.ostrascript",
                    "match": "="
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.ostrascript",
                    "match": "\\b(kaj|inak|kajinak|fajront|rubat|zkus|chujstym|fofrem|pockej|smrt|naposled|mrdni|novabuchta)\\b"
                },
                {
                    "name": "storage.type.ostrascript",
                    "match": "\\b(kalfas|toz|konstatuj|tryda|typ|pruser|slyb)\\b"
                },
                {
                    "name": "keyword.operator.logical.ostrascript",
                    "match": "\\b(aj|ci|ajbit|cibit)\\b"
                },
                {
                    "name": "support.function.ostrascript",
                    "match": "\\b(hovor|rubej)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.numeric.ostrascript",
                    "match": "\\b[0-9]+(?:\\.[0-9]+)?\\b"
                },
                {
                    "name": "constant.language.ostrascript",
                    "match": "\\b(laces|bokdepa|chuj|kokot|nist|dynamit)\\b"
                }
            ]
        },
        "main": {
            "patterns": [
                {
                    "include": "#comments"
                },
                {
                    "include": "#strings"
                },
                {
                    "include": "#generics"
                },
                {
                    "include": "#operators"
                },
                {
                    "include": "#keywords"
                },
                {
                    "include": "#constants"
                }
            ]
        }
    }
}