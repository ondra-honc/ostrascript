{
    "name": "Ostrascript",
    "scopeName": "source.os",
    "patterns": [
        {
            "include": "#main"
        }
    ],
    "repository": {
        "main": {
            "patterns": [
                {
                    "include": "#comments"
                },
                {
                    "include": "#strings"
                },
                {
                    "include": "#operators"
                },
                {
                    "include": "#keywords"
                },
                {
                    "include": "#constants"
                },
                {
                    "include": "#functions"
                },
                {
                    "include": "#types"
                }
            ]
        },
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.ostrascript",
                    "match": "//.*$"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.ostrascript",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "include": "#string-internals"
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.ostrascript",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "include": "#string-internals-no-interpolation"
                        }
                    ]
                },
                {
                    "name": "string.quoted.template.ostrascript",
                    "begin": "`",
                    "end": "`",
                    "patterns": [
                        {
                            "include": "#string-internals"
                        }
                    ]
                }
            ]
        },
        "string-internals-no-interpolation": {
            "patterns": [
                {
                    "name": "constant.character.escape.ostrascript",
                    "match": "\\\\."
                }
            ]
        },
        "string-internals": {
            "patterns": [
                {
                    "include": "#string-internals-no-interpolation"
                },
                {
                    "name": "meta.interpolation.ostrascript",
                    "begin": "(\\$)(\\{)",
                    "beginCaptures": {
                        "1": {
                            "name": "keyword.operator.interpolation.ostrascript"
                        },
                        "2": {
                            "name": "keyword.operator.interpolation.ostrascript"
                        }
                    },
                    "end": "(\\})",
                    "endCaptures": {
                        "1": {
                            "name": "keyword.operator.interpolation.ostrascript"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#main"
                        }
                    ]
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "storage.type.function.arrow.ostrascript", 
                    "match": "=>"
                },
                {
                    "name": "keyword.operator.ostrascript",
                    "match": "(<|>|===|==|!=|=|[*+\\-%/])"
                }
            ]
        },

        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.ostrascript",
                    "match": "\\b(kaj|inak|kajinak|fajront|rubat|zkus|chujstym|fofrem|pockej|smrt|naposled|mrdni|novabuchta|jebnato|dalsy|pro|vrat|mensy|mensyrovno|vetsy|vetsyrovno)\\b"
                },
                {
                    "name": "storage.type.ostrascript",
                    "match": "\\b(kalfas|toz|konstatuj|tryda|typ|pruser|slyb|vythani|posly|tohle|zrus|typni|vlastnost)\\b"
                },
                {
                    "name": "keyword.operator.logical.ostrascript",
                    "match": "\\b(aj|ci|ajbit|cibit)\\b"
                },
                {
                    "name": "support.function.ostrascript",
                    "match": "\\b(hovor|rubej|buchtoklyce|buchtohody|rozemel)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.numeric.ostrascript",
                    "match": "\\b[0-9]+(?:\\.[0-9]+)?\\b"
                },
                {
                    "name": "constant.language.ostrascript",
                    "match": "\\b(laces|bokdepa|chuj|kokot|nist|dynamit)\\b"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "meta.function-call.ostrascript",
                    "match": "(\\b[a-zA-Z_$][\\w$]*)(\\()",
                    "captures": {
                        "1": {
                            "name": "entity.name.function.ostrascript"
                        }
                    }
                },
                {
                    "name": "meta.method-call.ostrascript",
                    "match": "(\\.([a-zA-Z_$][\\w$]*))",
                    "captures": {
                        "2": {
                            "name": "entity.name.function.ostrascript"
                        }
                    }
                },
                {
                    "name": "meta.function.definition.ostrascript",
                    "match": "\\b(kalfas)\\s+([a-zA-Z_$][\\w$]*)",
                    "captures": {
                        "1": {
                            "name": "storage.type.ostrascript"
                        },
                        "2": {
                            "name": "entity.name.function.ostrascript"
                        }
                    }
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "meta.type.definition.ostrascript",
                    "match": "\\b(typ)\\s+([a-zA-Z_$][\\w$]*)",
                    "captures": {
                        "1": { "name": "storage.type.ostrascript" },
                        "2": { "name": "entity.name.type.ostrascript" }
                    }
                }
            ]
        }
    }
}