{
  "name": "ostrascript",
  "displayName": "Ostrascript",
  "publisher": "ondrej-honc",
  "version": "1.1.3",
  "icon": "icon.png",
  "license": "MIT",
  "keywords": [
    "ostrava",
    "programming",
    "language",
    "syntax"
  ],
  "galleryBanner": {
    "color": "#C0392B",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.80.0" 
  },
  "activationEvents": [
    "onLanguage:ostrascript"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ostrascript",
        "aliases": [
          "Ostrascript",
          "os"
        ],
        "extensions": [
          ".os"
        ],
        "configuration": "./language.json",
        "icon": {
          "light": "./logo.svg",
          "dark": "./logo.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "ostrascript",
        "scopeName": "source.os",
        "path": "./syntax.json"
      }
    ],
    "semanticTokenTypes": [
      {
        "id": "parameter",
        "description": "Parametry funkci a chujstym"
      },
      {
        "id": "type",
        "description": "Datove typy"
      },
      {
        "id": "function",
        "description": "Nazvy funkci"
      }
    ],
    "semanticTokenModifiers": [],
    "semanticTokenColors": {
      "parameter": {
        "foreground": "#9CDCFE"
      },
      "function": {
        "foreground": "#DCDCAA"
      },
      "type": {
        "foreground": "#4EC9B0"
      }
    }
  },
  "description": "Nejostřejší rozšíření pro nejostřejší jazyk na světě. Přidává podporu pro syntaxi a barvičky pro soubory .os.",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.3.3"
  },
  "author": ""
}